<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for Social Sparks
    Designed to be colourful, fun, and easy for Cora to use on busy days.
    The layout scrolls so it works nicely on smaller screens too.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        tools:context=".MainActivity">

        <!-- App Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Social Sparks ✨"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="40dp"
            android:fontFamily="sans-serif-medium" />

        <!-- Friendly subtitle to explain the app -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="16sp"
            android:textColor="#EEFFFFFF"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <!-- A little instruction for the user -->
        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tell me the time of day, and I'll give you a social spark! 💡"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="24dp"
            android:gravity="center" />

        <!-- Text input where the user types the time of day -->
        <EditText
            android:id="@+id/etTimeOfDay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_rounded_input"
            android:hint="@string/hint_time_of_day"
            android:textSize="16sp"
            android:textColor="@color/dark_text"
            android:textColorHint="@color/light_text"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:importantForAutofill="no" />

        <!-- Main action button - Get My Spark -->
        <Button
            android:id="@+id/btnGetSpark"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_spark"
            android:text="@string/btn_get_spark"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium" />

        <!-- This card area shows the suggestion or error message -->
        <LinearLayout
            android:id="@+id/suggestionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_suggestion_card"
            android:padding="24dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:elevation="4dp"
            android:minHeight="120dp"
            android:visibility="visible">

            <!-- Label above the suggestion -->
            <TextView
                android:id="@+id/tvSuggestionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Social Spark"
                android:textSize="14sp"
                android:textColor="@color/light_text"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- The actual suggestion text -->
            <TextView
                android:id="@+id/tvSuggestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_suggestion"
                android:textSize="18sp"
                android:textColor="@color/dark_text"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Reset button to clear everything and start fresh -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_button_reset"
            android:text="@string/btn_reset"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAllCaps="false" />

    </LinearLayout>

</ScrollView>
